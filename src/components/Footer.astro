---
import LogoDevice from './LogoDevice.astro';
import IconPhone from './icons/IconPhone.astro';
import IconEnvelope from './icons/IconEnvelope.astro';
import { navItems } from '../data/navigation';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">

    <div class="site-footer__top">
      <a href="/" class="site-footer__logo" aria-label="23.4° — home">
        <LogoDevice class="site-footer__logo-device" />
        23.4<span class="degree" aria-hidden="true">&deg;</span>
      </a>
      <p class="site-footer__tagline">Slightly Tilted.</p>
      <div class="site-footer__contact">
        <a href="tel:07428443110" class="site-footer__phone">
          <IconPhone /> 07428 443110
        </a>
        <a href="#" class="site-footer__email" data-u="info" data-d="23point4" data-t="uk" aria-label="Email us">
          <IconEnvelope />
          <span class="site-footer__email-text">info&#91;at&#93;23point4.uk</span>
        </a>
      </div>
    </div>

    <div class="site-footer__divider" aria-hidden="true"></div>

    <div class="site-footer__bottom">
      <nav class="site-footer__nav" aria-label="Footer">
        <ul class="site-footer__nav-list">
          {navItems.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>

      <p class="site-footer__legal">
        &copy; {year} 23.4&deg;. All rights reserved, like.
        <span class="site-footer__location">Built in Tameside, Manchester. Fuelled by tea.</span>
      </p>
    </div>

  </div>
</footer>

<script>
  const emailLink = document.querySelector('.site-footer__email') as HTMLAnchorElement | null;
  if (emailLink) {
    const u = emailLink.dataset.u;
    const d = emailLink.dataset.d;
    const t = emailLink.dataset.t;
    const email = `${u}@${d}.${t}`;
    emailLink.href = `mailto:${email}`;
    const span = emailLink.querySelector('.site-footer__email-text');
    if (span) span.textContent = email;
  }
</script>

<style>
  .site-footer {
    padding-block: var(--space-xl) var(--space-lg);
    background:
      radial-gradient(ellipse at 0% 0%, rgba(53, 74, 56, 0.6) 0%, transparent 60%),
      radial-gradient(ellipse at 100% 100%, rgba(53, 74, 56, 0.25) 0%, transparent 50%),
      var(--color-millstone);
    color: var(--color-drizzle);
  }

  /* Top — logo + strapline */
  .site-footer__top {
    padding-bottom: 1rem;
  }

  .site-footer__contact {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xs);
  }

  .site-footer__logo {
    font-family: var(--font-logo);
    font-size: clamp(1.75rem, 1.25rem + 2.5vw, 3rem);
    color: var(--color-mist);
    text-decoration: none;
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .site-footer__logo :global(.site-footer__logo-device) {
    height: 1.1em;
    width: auto;
    flex-shrink: 0;
  }

  .degree {
    font-size: 0.55em;
    vertical-align: super;
  }

  .site-footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-bracken-light);
    margin-top: var(--space-xs);
  }

  /* Divider */
  .site-footer__divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.1);
    margin-bottom: var(--space-md);
  }

  /* Bottom — nav + legal */
  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .site-footer__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
  }

  .site-footer__nav-list a {
    color: var(--color-gritstone);
    font-size: var(--text-sm);
    transition: color var(--duration) var(--ease-out);
  }

  .site-footer__nav-list a:hover {
    color: var(--color-mist);
  }

  .site-footer__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-bracken-light);
    text-decoration: none;
  }

  .site-footer__phone:hover {
    color: var(--color-mist);
  }

  .site-footer__email {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-bracken-light);
    text-decoration: none;
  }

  .site-footer__email:hover {
    color: var(--color-mist);
  }

  .site-footer__legal {
    font-size: var(--text-sm);
    color: var(--color-gritstone);
  }

  .site-footer__location {
    display: block;
    margin-top: 0.2rem;
  }

  @media (min-width: 768px) {
    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .site-footer__legal {
      text-align: right;
    }
  }
</style>
