---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">

    <div class="site-footer__top">
      <a href="/" class="site-footer__logo" aria-label="23.4° — home">
        <svg aria-hidden="true" class="site-footer__logo-device" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 124.29 101.86"><path fill="currentColor" d="M124.29,22.79l-16.83,4.47C96.16,4.52,68.79-5.69,45.2,4.52l-1.96-4.52C17.11,11.31,4.69,41.11,14.64,67.46L0,76.58l16.67-4.43c12.4,25.3,42.63,36.64,68.76,25.33l-1.96-4.52c23.59-10.21,34.89-37.14,26.04-60.96l14.78-9.2ZM81.88,89.29c-22.36,9.67-48.42-.64-58.09-23-9.68-22.36.64-48.42,23-58.09,22.36-9.68,48.42.64,58.09,23,9.68,22.36-.64,48.42-23,58.09Z"/></svg>
        23.4<span class="degree" aria-hidden="true">&deg;</span>
      </a>
      <p class="site-footer__tagline">Slightly Tilted.</p>
    </div>

    <div class="site-footer__divider" aria-hidden="true"></div>

    <div class="site-footer__bottom">
      <nav class="site-footer__nav" aria-label="Footer">
        <ul class="site-footer__nav-list">
          <li><a href="#services">What We Do</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#testimonials">Kind Words</a></li>
          <li><a href="#contact">Get In Touch</a></li>
        </ul>
      </nav>

      <p class="site-footer__legal">
        &copy; {year} 23.4&deg;. All rights reserved, like.
        <span class="site-footer__location">Built in Tameside, Manchester. Fuelled by tea.</span>
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    padding-block: var(--space-xl) var(--space-lg);
    background:
      radial-gradient(ellipse at 0% 0%, rgba(53, 74, 56, 0.35) 0%, transparent 55%),
      radial-gradient(ellipse at 100% 100%, rgba(181, 112, 59, 0.1) 0%, transparent 50%),
      var(--color-millstone);
    color: var(--color-drizzle);
  }

  /* Top — logo + strapline */
  .site-footer__top {
    padding-bottom: var(--space-lg);
  }

  .site-footer__logo {
    font-family: var(--font-logo);
    font-size: clamp(1.75rem, 1.25rem + 2.5vw, 3rem);
    color: var(--color-mist);
    text-decoration: none;
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .site-footer__logo-device {
    height: 1.1em;
    width: auto;
    flex-shrink: 0;
  }

  .degree {
    font-size: 0.55em;
    vertical-align: super;
  }

  .site-footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-bracken-light);
    margin-top: var(--space-xs);
  }

  /* Divider */
  .site-footer__divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.1);
    margin-bottom: var(--space-md);
  }

  /* Bottom — nav + legal */
  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .site-footer__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
  }

  .site-footer__nav-list a {
    color: var(--color-gritstone);
    font-size: var(--text-sm);
    transition: color var(--duration) var(--ease-out);
  }

  .site-footer__nav-list a:hover {
    color: var(--color-mist);
  }

  .site-footer__legal {
    font-size: var(--text-sm);
    color: var(--color-gritstone);
  }

  .site-footer__location {
    display: block;
    margin-top: 0.2rem;
  }

  @media (min-width: 768px) {
    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .site-footer__legal {
      text-align: right;
    }
  }
</style>
