---
const testimonials = [
  {
    quote: 'They built us a website that actually made sense. No jargon, no messing about — just a site that works and looks the business. Proper impressed.',
    name: 'Sarah T.',
    role: 'Owner, Independent Retailer',
  },
  {
    quote: 'Honestly expected the usual agency runaround. Instead, they just got on with it, kept us in the loop, and delivered something bang on. Would recommend to anyone.',
    name: 'James P.',
    role: 'Managing Director, B2B Services',
  },
  {
    quote: 'The SEO work has been a slow burn — they told us it would be, which we appreciated — but six months in and we\'re seeing proper results. No smoke and mirrors.',
    name: 'Rachel K.',
    role: 'Marketing Manager',
  },
];
---

<section id="testimonials" class="testimonials">
  <div class="container">
    <header class="testimonials__header" data-reveal>
      <p class="testimonials__kicker">Kind Words</p>
      <h2 class="testimonials__title">What people have said</h2>
    </header>

    <ul class="testimonials__list testimonials__list--rotating" id="rotating-quotes">
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
    </ul>

    <header class="testimonials__header testimonials__header--actual" data-reveal>
      <h2 class="testimonials__title">What people have actually said <em>about us</em></h2>
    </header>

    <ul class="testimonials__list">
      {testimonials.map(({ quote, name, role }) => (
        <li class="testimonials__card" data-reveal>
          <blockquote class="testimonials__quote">
            <p>"{quote}"</p>
          </blockquote>
          <footer class="testimonials__attribution">
            <cite class="testimonials__name">{name}</cite>
            <span class="testimonials__role">{role}</span>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testimonials {
    padding-block: var(--space-xl);
    background:
      radial-gradient(ellipse at 50% 0%, rgba(151, 133, 115, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 100% 100%, rgba(53, 74, 56, 0.07) 0%, transparent 50%),
      var(--color-bg-alt);
  }

  .testimonials__header {
    margin-bottom: var(--space-lg);
  }

  .testimonials__header--actual {
    margin-top: var(--space-xl);
  }

  .testimonials__kicker {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .testimonials__title {
    font-size: var(--text-2xl);
  }



  .testimonials__list {
    display: grid;
    gap: var(--space-md);
  }

  .testimonials__card {
    background-color: var(--color-snow);
    border-radius: 0.5rem;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: space-between;
  }

  .testimonials__card .testimonials__quote,
  .testimonials__card .testimonials__attribution {
    transition: opacity 0.6s var(--ease-out);
  }

  .testimonials__card.is-fading .testimonials__quote,
  .testimonials__card.is-fading .testimonials__attribution {
    opacity: 0;
  }

  .testimonials__quote p {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--color-heading);
  }

  .testimonials__attribution {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonials__name {
    font-weight: 600;
    font-style: normal;
    color: var(--color-accent);
  }

  .testimonials__role {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .testimonials__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

