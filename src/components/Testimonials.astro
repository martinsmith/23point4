---
import SectionHeader from './SectionHeader.astro';

const testimonials = [
  {
    quote: 'They built us a website that actually made sense. No jargon, no messing about — just a site that works and looks the business. Proper impressed.',
    name: 'Sarah T.',
    role: 'Owner, Independent Retailer',
  },
  {
    quote: 'Honestly expected the usual agency runaround. Instead, they just got on with it, kept us in the loop, and delivered something bang on. Would recommend to anyone.',
    name: 'James P.',
    role: 'Managing Director, B2B Services',
  },
  {
    quote: 'The SEO work has been a slow burn — they told us it would be, which we appreciated — but six months in and we\'re seeing proper results. No smoke and mirrors.',
    name: 'Rachel K.',
    role: 'Marketing Manager',
  },
];
---

<section id="testimonials" class="testimonials">
  <div class="container">
    <SectionHeader kicker="Kind Words" title="What people have said" />

    <ul class="testimonials__list testimonials__list--rotating" id="rotating-quotes">
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
      <li class="testimonials__card" data-reveal>
        <blockquote class="testimonials__quote"><p></p></blockquote>
        <footer class="testimonials__attribution">
          <span class="testimonials__role"></span>
        </footer>
      </li>
    </ul>

    <SectionHeader title='What people have actually said <em>about us</em>' class="testimonials__header--actual" />

    <ul class="testimonials__list">
      {testimonials.map(({ quote, name, role }) => (
        <li class="testimonials__card" data-reveal>
          <blockquote class="testimonials__quote">
            <p>"{quote}"</p>
          </blockquote>
          <footer class="testimonials__attribution">
            <cite class="testimonials__name">{name}</cite>
            <span class="testimonials__role">{role}</span>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testimonials {
    padding-block: var(--space-xl);
    background:
      radial-gradient(ellipse at 50% 0%, rgba(151, 133, 115, 0.28) 0%, transparent 60%),
      radial-gradient(ellipse at 100% 100%, rgba(151, 133, 115, 0.12) 0%, transparent 50%),
      var(--color-bg-alt);
  }

  :global(.testimonials__header--actual) {
    margin-top: var(--space-xl);
  }

  .testimonials__list {
    display: grid;
    gap: var(--space-md);
  }

  .testimonials__card {
    background-color: var(--color-snow);
    border-radius: 0.5rem;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    justify-content: space-between;
  }

  .testimonials__card .testimonials__quote,
  .testimonials__card .testimonials__attribution {
    transition: opacity 0.6s var(--ease-out);
  }

  .testimonials__card.is-fading .testimonials__quote,
  .testimonials__card.is-fading .testimonials__attribution {
    opacity: 0;
  }

  .testimonials__quote p {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--color-heading);
  }

  .testimonials__attribution {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonials__name {
    font-weight: 600;
    font-style: normal;
    color: var(--color-accent);
  }

  .testimonials__role {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .testimonials__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  import { funnyQuotes, attributionLabels, type Quote } from '../data/quotes';

  function shuffle(arr: Quote[]): Quote[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  let pool = shuffle(funnyQuotes);
  let poolIndex = 0;

  function getNextQuotes(count: number): Quote[] {
    const result: Quote[] = [];
    for (let i = 0; i < count; i++) {
      if (poolIndex >= pool.length) {
        pool = shuffle(funnyQuotes);
        poolIndex = 0;
      }
      result.push(pool[poolIndex++]);
    }
    return result;
  }

  function renderCards(cards: NodeListOf<Element>, data: Quote[]): void {
    cards.forEach((card, i) => {
      const q = data[i];
      const p = card.querySelector('.testimonials__quote p');
      const role = card.querySelector('.testimonials__role');
      if (p) p.textContent = `"${q.quote}"`;
      if (role) role.textContent = attributionLabels[Math.floor(Math.random() * attributionLabels.length)];
    });
  }

  function rotateQuotes(): void {
    const cards = document.querySelectorAll('#rotating-quotes .testimonials__card');
    cards.forEach((c) => c.classList.add('is-fading'));

    setTimeout(() => {
      renderCards(cards, getNextQuotes(3));
      cards.forEach((c) => c.classList.remove('is-fading'));
    }, 600);
  }

  // Initial render
  const cards = document.querySelectorAll('#rotating-quotes .testimonials__card');
  renderCards(cards, getNextQuotes(3));

  // Rotate every 12 seconds (respect reduced motion)
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    setInterval(rotateQuotes, 12000);
  }
</script>