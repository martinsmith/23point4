  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  let pool = shuffle(quotes);
  let poolIndex = 0;

  function getNextQuotes(count) {
    const result = [];
    for (let i = 0; i < count; i++) {
      if (poolIndex >= pool.length) {
        pool = shuffle(quotes);
        poolIndex = 0;
      }
      result.push(pool[poolIndex++]);
    }
    return result;
  }

  function renderCards(cards, data) {
    cards.forEach((card, i) => {
      const q = data[i];
      const p = card.querySelector('.testimonials__quote p');
      const role = card.querySelector('.testimonials__role');
      if (p) p.textContent = `"${q.quote}"`;
      const roles = [
        'Someone off T.V. or something',
        'A wonderful person',
        'Obviously not a client',
        'Someone\'s mate, probably',
        'A person of some note',
        'Definitely not made up',
        'A real human being',
        'Someone important, apparently',
        'Off the telly',
        'A national treasure, arguably',
        'Someone who said a thing once',
        'A reliable source',
        'Heard it down the pub',
        'A person with opinions',
        'Someone who gets it',
      ];
      if (role) role.textContent = roles[Math.floor(Math.random() * roles.length)];
    });
  }

  function rotateQuotes() {
    const cards = document.querySelectorAll('#rotating-quotes .testimonials__card');
    // Fade out
    cards.forEach((c) => c.classList.add('is-fading'));

    setTimeout(() => {
      renderCards(cards, getNextQuotes(3));
      // Fade in
      cards.forEach((c) => c.classList.remove('is-fading'));
    }, 600);
  }

  // Initial render
  const cards = document.querySelectorAll('#rotating-quotes .testimonials__card');
  renderCards(cards, getNextQuotes(3));

  // Rotate every 12 seconds (respect reduced motion)
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!prefersReducedMotion.matches) {
    setInterval(rotateQuotes, 12000);
  }
</script>