<section id="contact" class="contact">
  <div class="container contact__inner">
    <header class="contact__header" data-reveal>
      <p class="contact__kicker">Get In Touch</p>
      <h2 class="contact__title">Go on then, drop us a line</h2>
      <p class="contact__subtitle">
        We'll get back to you within a day or so. We're usually busy doing actual work.
      </p>
    </header>

    <form class="contact__form" action="#" method="post" data-reveal>
      <div class="contact__field">
        <label for="contact-name" class="contact__label">Your Name</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          class="contact__input"
          required
          autocomplete="name"
          placeholder="e.g. Our Kid"
        />
      </div>

      <div class="contact__field">
        <label for="contact-email" class="contact__label">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          class="contact__input"
          required
          autocomplete="email"
          placeholder="youremail@example.com"
        />
      </div>

      <div class="contact__field contact__field--full">
        <label for="contact-message" class="contact__label">
          What's on your mind?
        </label>
        <textarea
          id="contact-message"
          name="message"
          class="contact__textarea"
          rows="5"
          required
          placeholder="Tell us what you need. Or just say hiya."
        ></textarea>
      </div>

      <div class="contact__field contact__field--full">
        <button type="submit" class="contact__submit">
          Send it over
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-xl);
    background-color: var(--color-bg);
  }

  .contact__inner {
    display: grid;
    gap: var(--space-lg);
  }

  .contact__kicker {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .contact__title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .contact__subtitle {
    color: var(--color-text-muted);
    max-width: 50ch;
    line-height: 1.6;
  }

  .contact__form {
    display: grid;
    gap: var(--space-md);
  }

  .contact__label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-xs);
  }

  .contact__input,
  .contact__textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background-color: var(--color-snow);
    border: 1.5px solid var(--color-drizzle);
    border-radius: 0.375rem;
    transition: border-color var(--duration) var(--ease-out);
  }

  .contact__input:focus-visible,
  .contact__textarea:focus-visible {
    border-color: var(--color-pennine);
    box-shadow: 0 0 0 3px rgba(44, 62, 45, 0.1);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contact__input::placeholder,
  .contact__textarea::placeholder {
    color: var(--color-gritstone);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-snow);
    background-color: var(--color-accent);
    border-radius: 0.375rem;
    transition: all var(--duration) var(--ease-out);
  }

  .contact__submit:hover {
    background-color: var(--color-bracken-light);
    transform: translateY(-1px);
  }

  @media (min-width: 768px) {
    .contact__inner {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    .contact__form {
      grid-template-columns: 1fr 1fr;
    }

    .contact__field--full {
      grid-column: 1 / -1;
    }
  }
</style>
