---
const navItems = [
  { label: 'What We Do', href: '#services' },
  { label: 'About', href: '#about' },
  { label: 'Kind Words', href: '#testimonials' },
  { label: 'Get In Touch', href: '#contact' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="23.4° — home">
      <svg aria-hidden="true" class="site-header__logo-device" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 101.86 124.29"><path fill="currentColor" d="M79.07,0l-9.2,14.78c-23.82-8.84-50.75,2.45-60.96,26.04l-4.52-1.96c-11.31,26.13.03,56.36,25.33,68.76l-4.43,16.67,9.12-14.64c26.36,9.96,56.16-2.47,67.46-28.6l-4.52-1.96c10.21-23.59,0-50.96-22.75-62.27L79.07,0ZM93.67,77.5c-9.67,22.36-35.74,32.68-58.09,23S2.9,64.77,12.57,42.41,48.31,9.73,70.67,19.41c22.36,9.68,32.68,35.74,23,58.09Z"/></svg>
      23.4<span class="degree" aria-hidden="true">&deg;</span>
    </a>

    <button
      class="site-header__toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="site-header__toggle-bar"></span>
      <span class="site-header__toggle-bar"></span>
      <span class="site-header__toggle-bar"></span>
    </button>

    <nav id="primary-nav" class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {navItems.map(({ label, href }) => (
          <li>
            <a href={href} class="site-header__nav-link">{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.site-header__toggle');
  const nav = document.getElementById('primary-nav');
  const header = document.querySelector('.site-header');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    nav?.classList.toggle('is-open');
    header?.classList.toggle('is-open');
  });

  // Close menu on link click
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      nav?.classList.remove('is-open');
      header?.classList.remove('is-open');
    });
  });

  // Solid background on scroll
  const onScroll = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: var(--space-sm);
    transition: background-color var(--duration) var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
  }

  .site-header.is-scrolled {
    background-color: var(--color-mist);
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
  }

  .site-header.is-open {
    background-color: var(--color-pennine);
    box-shadow: none;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header__logo {
    font-family: var(--font-logo);
    font-size: var(--text-xl);
    color: var(--color-heading);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color var(--duration) var(--ease-out);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .site-header__logo-device {
    height: 1.1em;
    width: auto;
    flex-shrink: 0;
  }

  .is-open .site-header__logo {
    color: var(--color-text-inv);
  }

  .degree {
    font-size: 0.6em;
    vertical-align: super;
  }

  .site-header__toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    z-index: 101;
  }

  .site-header__toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-heading);
    transition: all var(--duration) var(--ease-out);
  }

  .is-open .site-header__toggle-bar {
    background-color: var(--color-text-inv);
  }

  .site-header__nav {
    position: fixed;
    inset: 0;
    background-color: var(--color-pennine);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all var(--duration) var(--ease-out);
  }

  .site-header__nav.is-open {
    opacity: 1;
    visibility: visible;
  }

  .site-header__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-align: center;
  }

  .site-header__nav-link {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text-inv);
    text-decoration: none;
    transition: opacity var(--duration) var(--ease-out);
  }

  .site-header__nav-link:hover {
    opacity: 0.7;
    color: var(--color-text-inv);
  }

  @media (min-width: 768px) {
    .site-header__toggle { display: none; }

    .site-header__nav {
      position: static;
      background: none;
      opacity: 1;
      visibility: visible;
    }

    .site-header__nav-list {
      flex-direction: row;
      gap: var(--space-md);
    }

    .site-header__nav-link {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      color: var(--color-text);
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .site-header__nav-link:hover {
      color: var(--color-accent);
      opacity: 1;
    }
  }
</style>
