---
const navItems = [
  { label: 'What We Do', href: '#services' },
  { label: 'About', href: '#about' },
  { label: 'Kind Words', href: '#testimonials' },
  { label: 'Get In Touch', href: '#contact' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="23.4° — home">
      <svg aria-hidden="true" class="site-header__logo-device" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 124.29 101.86"><path fill="currentColor" d="M124.29,22.79l-16.83,4.47C96.16,4.52,68.79-5.69,45.2,4.52l-1.96-4.52C17.11,11.31,4.69,41.11,14.64,67.46L0,76.58l16.67-4.43c12.4,25.3,42.63,36.64,68.76,25.33l-1.96-4.52c23.59-10.21,34.89-37.14,26.04-60.96l14.78-9.2ZM81.88,89.29c-22.36,9.67-48.42-.64-58.09-23-9.68-22.36.64-48.42,23-58.09,22.36-9.68,48.42.64,58.09,23,9.68,22.36-.64,48.42-23,58.09Z"/></svg>
      23.4<span class="degree" aria-hidden="true">&deg;</span>
    </a>

    <button
      class="site-header__toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="site-header__toggle-bar"></span>
      <span class="site-header__toggle-bar"></span>
      <span class="site-header__toggle-bar"></span>
    </button>

    <nav id="primary-nav" class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {navItems.map(({ label, href }) => (
          <li>
            <a href={href} class="site-header__nav-link">{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.site-header__toggle');
  const nav = document.getElementById('primary-nav');
  const header = document.querySelector('.site-header');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    nav?.classList.toggle('is-open');
    header?.classList.toggle('is-open');
  });

  // Close menu on link click
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      nav?.classList.remove('is-open');
      header?.classList.remove('is-open');
    });
  });

  // Solid background on scroll
  const onScroll = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: var(--space-sm);
    transition: background-color var(--duration) var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
  }

  .site-header.is-scrolled {
    background-color: var(--color-mist);
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
  }

  .site-header.is-open {
    background-color: var(--color-pennine);
    box-shadow: none;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header__logo {
    font-family: var(--font-logo);
    font-size: var(--text-xl);
    color: var(--color-heading);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color var(--duration) var(--ease-out);
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .site-header__logo-device {
    height: 1.1em;
    width: auto;
    flex-shrink: 0;
  }

  .is-open .site-header__logo {
    color: var(--color-text-inv);
  }

  .degree {
    font-size: 0.6em;
    vertical-align: super;
  }

  .site-header__toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    z-index: 101;
  }

  .site-header__toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-heading);
    transition: all var(--duration) var(--ease-out);
  }

  .is-open .site-header__toggle-bar {
    background-color: var(--color-text-inv);
  }

  .site-header__nav {
    position: fixed;
    inset: 0;
    background-color: var(--color-pennine);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all var(--duration) var(--ease-out);
  }

  .site-header__nav.is-open {
    opacity: 1;
    visibility: visible;
  }

  .site-header__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-align: center;
  }

  .site-header__nav-link {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text-inv);
    text-decoration: none;
    transition: opacity var(--duration) var(--ease-out);
  }

  .site-header__nav-link:hover {
    opacity: 0.7;
    color: var(--color-text-inv);
  }

  @media (min-width: 768px) {
    .site-header__toggle { display: none; }

    .site-header__nav {
      position: static;
      background: none;
      opacity: 1;
      visibility: visible;
    }

    .site-header__nav-list {
      flex-direction: row;
      gap: var(--space-md);
    }

    .site-header__nav-link {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      color: var(--color-text);
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .site-header__nav-link:hover {
      color: var(--color-accent);
      opacity: 1;
    }
  }
</style>
