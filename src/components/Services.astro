---
const services = [
  {
    number: '01',
    title: 'Website Design & Development',
    description: 'We build websites that actually work — responsive, accessible, and built with clean code that loads fast and holds up under pressure. No unnecessary complexity, no framework for framework\'s sake. Just solid work that does the job properly.',
  },
  {
    number: '02',
    title: 'Search Engine Optimisation',
    description: 'We won\'t promise you page one by Tuesday — anyone who does is having you on. What we do is the work that actually compounds: solid technical foundations, smart content strategy, and honest reporting on what\'s moving the needle and what isn\'t.',
  },
  {
    number: '03',
    title: 'Tailored AI Solutions',
    description: 'We build bespoke AI tools that solve real problems — automating the tedious bits so your team can focus on the stuff that matters. No buzzwords, no "leveraging synergies". Just useful tools that work.',
  },
  {
    number: '04',
    title: 'Craft CMS Consultancy',
    description: 'Craft CMS is genuinely excellent, and we\'ve been building with it for years. If you need a content management system your editors will actually enjoy using, we can handle the full picture — setup, migration, custom plugins, and training. The full works.',
  },
  {
    number: '05',
    title: 'Website Hosting',
    description: 'We host the sites we build on managed infrastructure with daily backups, uptime monitoring, and someone who actually picks up when something goes wrong. No shared hosting, no nasty surprises — just reliable, looked-after hosting from people who care.',
  },
];
---

<section id="services" class="services">
  <div class="container">
    <header class="services__header" data-reveal>
      <p class="services__kicker">Services</p>
      <h2 class="services__title">What we're fairly good at</h2>
    </header>

    <ul class="services__list">
      {services.map(({ number, title, description }) => (
        <li class="services__item" data-reveal>
          <span class="services__number">{number}</span>
          <h3 class="services__item-title">{title}</h3>
          <p class="services__item-desc">{description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    padding-block: var(--space-xl);
    background:
      radial-gradient(ellipse at 100% 0%, rgba(74, 99, 73, 0.6) 0%, transparent 50%),
      radial-gradient(ellipse at 0% 100%, rgba(28, 35, 33, 0.5) 0%, transparent 45%),
      var(--color-bg-dark);
    color: var(--color-text-inv);
  }

  .services__header {
    margin-bottom: var(--space-lg);
  }

  .services__kicker {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bracken-light);
    margin-bottom: var(--space-xs);
  }

  .services__title {
    font-size: var(--text-2xl);
    color: var(--color-mist);
  }

  .services__list {
    display: grid;
  }

  .services__item {
    display: grid;
    gap: var(--space-sm);
    padding-block: var(--space-md);
    border-top: 1px solid var(--color-moorland);
  }

  .services__item:first-child {
    border-top: none;
  }

  .services__number {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-bracken-light);
  }

  .services__item-title {
    font-size: var(--text-xl);
    color: var(--color-mist);
  }

  .services__item-desc {
    max-width: 60ch;
    line-height: 1.7;
    color: var(--color-drizzle);
    font-size: var(--text-base);
  }

  @media (min-width: 768px) {
    .services__item {
      grid-template-columns: auto 1fr 2fr;
      align-items: start;
      gap: var(--space-md);
    }

    .services__item-desc {
      border-left: 1px solid var(--color-moorland);
      padding-left: var(--space-md);
    }
  }
</style>
