---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '23.4° — Your Perfectly Adequate Digital Partner',
  description = 'Digital marketing, web design & development from Manchester. We\'re not the flashiest agency going, but we\'re proper good at what we do.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-R4PRF2DENW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R4PRF2DENW');
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <script>
      import '../scripts/animations.js';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
